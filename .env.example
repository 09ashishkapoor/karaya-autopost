# Local generation does not require environment variables.
# Bluesky posting requires these credentials:
#
# BLUESKY_IDENTIFIER=
# BLUESKY_APP_PASSWORD=
# BLUESKY_PDS_HOST=https://bsky.social
#
# Tumblr posting and OAuth helper require these values:
#
# TUMBLR_CLIENT_ID=
# TUMBLR_CLIENT_SECRET=
# TUMBLR_REFRESH_TOKEN=
# TUMBLR_BLOG_IDENTIFIER=kakakaforadyakali.tumblr.com
# TUMBLR_REDIRECT_URI=
# TUMBLR_API_BASE=https://api.tumblr.com
