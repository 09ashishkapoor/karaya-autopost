      "posted_at": "2026-04-27T07:15:58.915236+00:00",
      "text_hash": "b20de68751c7a142d83dbfd770eb0820262ea98f6ff00a9bf43253aa1beaf5db",
      "post_text": "Today's name is Bhuutanaathaaya. The lord and master of all beings, including ghosts and spirits. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 3,
      "source_index": 3,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkhmfcrm5h2a",
      "cid": "bafyreidfxe3refnrvkks3ycepu6t7nom5zgiqwbjvap5kpoj57r6ibj4ue",
      "posted_at": "2026-04-27T08:06:12.764565+00:00",
      "text_hash": "3eaa7d4b3c0a3fae40dcdeada4ed3569d36c7257ec7a21d84293a712c6945fef",
      "post_text": "Today's name is Bhuutaatmane. The one who is the very soul and inner essence of all living beings. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 4,
      "source_index": 4,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkhpt6w54y2j",
      "cid": "bafyreihtxnycxkhyw6z3ftpmbz4sjbxfuzezseqbgjzctaj26ew2n4t2uq",
      "posted_at": "2026-04-27T09:07:39.682092+00:00",
      "text_hash": "edd6ded78d077b0b8536526045eaf792f2021e4eaefc83db2c4ec064f88a50eb",
      "post_text": "Today's name is Bhuutabhaavanaaya. The creator and nurturer of all beings in the universe. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 5,
      "source_index": 5,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkhssy5uy522",
      "cid": "bafyreiaw3enifc3k3bc572obqvf3vjmayiok2c4k2cnz63oefxa2ovnomi",
      "posted_at": "2026-04-27T10:01:13.835011+00:00",
      "text_hash": "104ed069db2699b355e038a1200f72f8f8a5c5617a881b82d07974c79b141069",
      "post_text": "Today's name is Bhuutavaasaaya. The one who dwells within all existence, and in whom all beings dwell. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 6,
      "source_index": 6,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkhw3araqg22",
      "cid": "bafyreia5apf7q4r5gir5of5reprwdbl26r63es4qvrgmio7w2x6n7sxbam",
      "posted_at": "2026-04-27T10:59:32.506189+00:00",
      "text_hash": "6933e991a83364076762a166216c72561a1cb3c9f14f3bc452fcbb735fa37c67",
      "post_text": "Today's name is Bhuutaduutaaya. The one who sends ghosts and spirits as his messengers. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 7,
      "source_index": 7,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkhz7ekn4s2g",
      "cid": "bafyreidectcepxemi72mk277evmhipocsslttozaaldwsuw7haumfafkle",
      "posted_at": "2026-04-27T11:55:31.922166+00:00",
      "text_hash": "dfe2e77e744d0a1f73519154a05e067f807c8ab3800048e26878000df0a23334",
      "post_text": "Today's name is Bhuurishaaya. The one who possesses great abundance and wealth. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 8,
      "source_index": 8,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mki4exweqy2u",
      "cid": "bafyreihkufghjttujevklysqom7s2uzrctdgs7avpfi5mwyyuax6uutoay",
