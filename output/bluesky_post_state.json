      "text_hash": "64379bd9576b919bce2a4b4014d53f8c0186d1f75ce5b9152b845c18a75dd609",
      "post_text": "Today's name is Bhuuridakshinaaya. The one who is deeply generous and grants great rewards. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 9,
      "source_index": 9,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkia44efgg2o",
      "cid": "bafyreifo72tvxmom2uwmpa5bh46nmcsfwzd7b4nhfi27rcj5o3v4wqtrou",
      "posted_at": "2026-04-27T13:58:58.858565+00:00",
      "text_hash": "792bf48d86c535cc990510d13d4584c2fa6a8ce2f0f42ce4bf1e2b84311daf6e",
      "post_text": "Today's name is Bhuutaadhyakshaaya. The supreme overseer who presides over all beings. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 10,
      "source_index": 10,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkidjvusjy2u",
      "cid": "bafyreiericiideqilkxzbuukxx6lb3cjibpaborx4huzs4lveuhnwg2c3a",
      "posted_at": "2026-04-27T15:00:23.066725+00:00",
      "text_hash": "470ffd4e2127c0249eb52096ad06f7eaea2074ed3a794e058de1c5e3c71c6b71",
      "post_text": "Today's name is Bhuutapataye. The commander and protector of all beings. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 11,
      "source_index": 11,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkignyclhx2n",
      "cid": "bafyreied3svs5c6j3d55ottunlrqjgw3ma5ruodx6qsftj6mdf6jyc7p2i",
      "posted_at": "2026-04-27T15:56:21.055126+00:00",
      "text_hash": "e27d2a9b44cc2bc3c9fe9512193caa86d6814307076313f0264faebddb0112b8",
      "post_text": "Today's name is Bhuudharaaya. The one who upholds the Earth. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 12,
      "source_index": 12,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkiju3hqjt2a",
      "cid": "bafyreicslau2d4bsfky2y2wwnzoo3tsmhjj2wgcocmwd7ylhdsr3o6z3cy",
      "posted_at": "2026-04-27T16:53:26.901654+00:00",
      "text_hash": "a1ea81c895c5944c176d10cb5b521e632b11bea4d0083cab1da0926e15be88db",
      "post_text": "Today's name is Bhuudharaatmajaaya. The son of the mountain-bearer; here, an epithet of Bhairava's power. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 13,
      "source_index": 13,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkims7o32g2q",
      "cid": "bafyreibicmvuhdiak73dh3a5xmzhmf6fm4dbpqch6ski64ernc3ba4akry",
      "posted_at": "2026-04-27T17:46:05.411190+00:00",
      "text_hash": "ec9769179f8f143331c2c45b5d4702737618cb2b8fcdb8e5efff7a47e9d9c21d",
      "post_text": "Today's name is Bhuupataye. The supreme lord of the Earth. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 14,
      "source_index": 14,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkioi65kqr2j",
      "cid": "bafyreicofs7rhjcflnfmdvfwekegork3af6slvha4kzwhdremwsbhddqs4",
      "posted_at": "2026-04-27T18:16:15.778360+00:00",
      "text_hash": "b0213ca128d928cabdd6617016e409dfab2d3689d464864857a255f7c07b1e68",
      "post_text": "Today's name is Bhaaskaraaya. The one who shines with the radiance of the sun. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 15,
      "source_index": 15,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkiqdtern42v",
      "cid": "bafyreibolivynmz62375kiqmfcnoylpqrd3vwz5obu3oy2a4x2oclbf7y4",
      "posted_at": "2026-04-27T18:49:37.752061+00:00",
      "text_hash": "b855af64d9169f7f416180869e2b91d5611522812354d7dbcda336c28ef0a1df",
      "post_text": "Today's name is Bhiirave. The one who is formidable and awe-inspiring. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 16,
      "source_index": 16,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkitoyrfst27",
      "cid": "bafyreifopbbu4efkucqmv4qybjg72m7swwmqno5auu6eelypm6t6bzcs5u",
      "posted_at": "2026-04-27T19:49:33.733310+00:00",
      "text_hash": "7e8aa1f7669dbc863b80dfdbf5d6efacd58e73019bbcf7665b362bde11b3d561",
      "post_text": "Today's name is Bhiimaaya. The one who is of immense and fearsome strength. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 17,
      "source_index": 17,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkiwkj7zte2s",
      "cid": "bafyreif67gaatgtgn6d526voxsfuypen6btqvrlwji5iinel25ukie56oq",
      "posted_at": "2026-04-27T20:40:44.435534+00:00",
      "text_hash": "029a633b107d94033cc68d399c8472813e20a0d548817d126fe6222af9ff219e",
      "post_text": "Today's name is Bhuumaye. The one who is the Earth itself. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 18,
      "source_index": 18,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkiycl2rdn2u",
      "cid": "bafyreibvag5tjdb6khjgxmoac3qczkkbcncesy6pewrtn6rbrvmf5hqbli",
      "posted_at": "2026-04-27T21:12:05.393834+00:00",
      "text_hash": "f47e8de662b0ca7eeb5b6176532f3518db225e3ee7f036a80fc2c91f31364d13",
      "post_text": "Today's name is Vibhuutidaaya. The bestower of sacred ash, divine powers, and prosperity. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 19,
      "source_index": 19,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkizr653k52y",
      "cid": "bafyreifh4zblnkoln6enxirbc635pyfa5arhdanhomjifrt4ye7r74jnni",
      "posted_at": "2026-04-27T21:38:08.896269+00:00",
      "text_hash": "d97e8668d71e470eae93b6be242de65d2df8cfc241485bb36e4d763e6dbfe6e8",
      "post_text": "Today's name is Bhuutaaya. The one who has come into being and exists as all creation. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 20,
      "source_index": 20,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkj3dtz2w52s",
      "cid": "bafyreiab5bhgng7mxiwk3nsilqjwwn4ebrinch3kl5udpnfu5qk3bhex2q",
      "posted_at": "2026-04-27T22:06:29.553584+00:00",
      "text_hash": "728532889aad853efc84cc72102d84085ceca23d592959fb74e40ec99346ed62",
      "post_text": "Today's name is Bhuukampanaaya. The one who can make the earth tremble. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 21,
      "source_index": 21,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkj4wqgmdx2y",
      "cid": "bafyreif73ed3uqkij2pgutqil7hsmtsj6zdwdcf4y6wjgiyagrvfaoo2xm",
      "posted_at": "2026-04-27T22:34:57.110846+00:00",
      "text_hash": "00d3f7e8598d254fabae6326007f6bd5bf7683605c7ed8e89cedd7aaf17cd8fb",
      "post_text": "Today's name is Bhuuminaamne. The one known through all the names of the Earth. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 22,
      "source_index": 22,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkj6sdotjg2j",
      "cid": "bafyreidvgs4md42zfhiuevsd3wumilqspjrxg2b7mbxe4xaqdr5zdv3ytq",
      "posted_at": "2026-04-27T23:08:16.994837+00:00",
      "text_hash": "6c10512364c0af68bd53bc6c597783a203b871411e48f99c1ed4923f82db5437",
      "post_text": "Today's name is Bhuutaabhibhaavakaaya. The one who summons, stirs, and manifests spirits. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 23,
      "source_index": 23,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjafiblyx2v",
      "cid": "bafyreidw6ffwkcqak45qsiuqfoonqbajc5ovmqm7d7ffxwqf2echt5zrs4",
      "posted_at": "2026-04-27T23:36:53.072870+00:00",
      "text_hash": "1a7e0354eca8eb925e378bb3e61b97437b32ed94afe1b925c36d704581bdd862",
      "post_text": "Today's name is Bhaganetraaya. The one who bears the eyes of Bhaga, the Vedic deity of fortune and prosperity. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 24,
      "source_index": 24,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjbzshxxy2v",
      "cid": "bafyreihgsa76cpyeajbstjzt5nwd76pjh2dnzfjbafnrlb7pdohyxaa2vq",
      "posted_at": "2026-04-28T00:06:08.596491+00:00",
      "text_hash": "8ef3736324e7f55afeaf090cf00ccc3c02a031ceb21933a7eef0cb6c5af5a813",
      "post_text": "Today's name is Bhavaaya. The one who is existence itself. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 25,
      "source_index": 25,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjfmtjlrv2o",
      "cid": "bafyreihk3lusitnrcbrzmmg2jcdfgbks7uuyuac7y5z7kxbhey7ebglojq",
      "posted_at": "2026-04-28T01:10:28.465255+00:00",
      "text_hash": "43a3dc19402b643db099260bdf6137a3ea7336f5e7ec04bc213489b4d2e11936",
      "post_text": "Today's name is Bhoktre. The one who is the ultimate enjoyer and experiencer. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 26,
      "source_index": 26,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjifzj6ld2q",
      "cid": "bafyreibjx64juyb4oka3o4qr7zf6fzwwfz67ncnqqqmukpxdjubuwbosse",
      "posted_at": "2026-04-28T02:00:21.105167+00:00",
      "text_hash": "2865fb01709b11a658944f4261bb42ffad42133608fc0edc35f1fc152ebb7585",
      "post_text": "Today's name is Bhuudevaaya. The one who is the divine presence upon Earth. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 27,
      "source_index": 27,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjndd3qwy2y",
      "cid": "bafyreifuohf2v3uzy6wtktcrsj3ekwa3mfyv3oiefylmrabyyf3sqtatka",
      "posted_at": "2026-04-28T03:28:19.194882+00:00",
      "text_hash": "8cd86f79be86fb19e04c9fee98f25c101fbd2e7c666e7a1085b6495452d4dcde",
      "post_text": "Today's name is Bhagavate. The divine and glorious Lord. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 28,
      "source_index": 28,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjsdmg7sp27",
      "cid": "bafyreih43kn2n5tmtubeej2ncooca74uobwz4mugiaxswsri2erg3s4zca",
      "posted_at": "2026-04-28T04:57:57.684967+00:00",
      "text_hash": "64780fc2b19c78afddd9023eb40dfe735801f4e330a0ca5d8c2b28b70550bb85",
      "post_text": "Today's name is Rathine. The one who rides the chariot, signifying mastery over the journey. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 29,
      "source_index": 29,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjwq5ulvc2j",
      "cid": "bafyreibet3g5vkjjoaxlh6vas2pj6pkrtgg5kygm2i4hn4o553mjlr2zuu",
      "posted_at": "2026-04-28T06:16:33.576336+00:00",
      "text_hash": "7fdc41bf61d427838413eec9902d255d0b7e05be7f135b3dbfb4cc6e12efd213",
      "post_text": "Today's name is Bhraajishnave. The one who blazes with splendid radiance. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 30,
      "source_index": 30,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkjzzl2vnb23",
      "cid": "bafyreiejxkw77r3e2mcionrd7xmkp2clqcltpqvwgwtl6rjibzdq6qrhya",
      "posted_at": "2026-04-28T07:15:30.635833+00:00",
      "text_hash": "34958f561cf67c9773749a3f7005b275329869627522ca85841fc974914dae0f",
      "post_text": "Today's name is Bhojanaaya. The one who is all food and nourishment. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 31,
      "source_index": 31,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkk4tl42ya23",
      "cid": "bafyreihktewepsewst3oxanww7dzsnrqyndu7uqjv3jo4tgetxqvmuvhn4",
      "posted_at": "2026-04-28T08:05:50.570557+00:00",
      "text_hash": "55706ff71c8dd38c8cf87318d4efb6fb2ef294616c16845cdc48dc99d9689120",
      "post_text": "Today's name is Bhoktre. The one who experiences and enjoys all that exists. Jai Bhairava Baba. #Kalabhairava"
    },
    {
      "queue_index": 32,
      "source_index": 32,
      "post_uri": "at://did:plc:otadxbi4rzrmydgsq5a4tg42/app.bsky.feed.post/3mkkachnurf2s",
